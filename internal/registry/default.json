{
  "hey_registry": 0,
  "apps": {
    "guten": {
      "description": "guten templating engine CLI (kitsy.ai)",
      "source": {
        "type": "github-release",
        "repo": "kitsyai/guten",
        "tag_prefix": "cli/",
        "asset_template": "guten_{version}_{os}_{arch}.{ext}",
        "checksums_asset": "checksums.txt",
        "binary": "guten"
      },
      "ui_commands": ["ui"]
    },
    "djin": {
      "description": "djin compliance suite (heypkv.ai)",
      "source": {
        "type": "github-release",
        "repo": "heypkv/djin",
        "tag_prefix": "",
        "asset_template": "djin_{version}_{os}_{arch}.{ext}",
        "checksums_asset": "checksums.txt",
        "binary": "djin"
      },
      "ui_commands": ["ui"]
    }
  },
  "scopes": {
    "heypkv": {
      "manifest_url": "https://cdn.heypkv.ai/hey/{id}/{channel}.json",
      "default_channel": "stable"
    }
  }
}
